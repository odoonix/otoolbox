{
    "folders": [
        {
            "path": ".",
            "name": "Odoo 19.0"
        }
    ],
    "launch": {
        "version": "0.2.0",
        "inputs": [
            {
                "id": "databaseName",
                "type": "command",
                "command": "extension.commandvariable.number",
                "args": {
                    "name": "databaseName",
                    "range": [
                        1500,
                        60000000
                    ],
                    "random": true,
                    "uniqueCount": 10
                }
            },
            {
                "id": "moduleList",
                "type": "pickString",
                "description": "List of Module to test, leave empty for all module",
                "options": [
                    "exchange,base_model_validation,australia_austrac,base_model_validation",
                    "connector_base",
                    "connector_base,connector_xero",
                    "connector_base,connector_shopify,connector_shopify_account"
                ],
                "default": "web"
            },
            {
                "id": "testTag",
                "type": "pickString",
                "description": "Tags to use in test",
                "options": [
                    "exchange,base_model_validation,australia_austrac,base_model_validation",
                    "connector_base",
                    "connector_base,connector_xero",
                    "connector_base,connector_shopify,connector_shopify_account"
                ],
                "default": "web"
            }
        ],
        "configurations": [
            {
                "name": "Odoo Run",
                "type": "debugpy",
                "request": "launch",
                "program": "${config:odoo.bin}",
                "console": "integratedTerminal",
                "justMyCode": true,
                "args": [
                    "--db_host",
                    "localhost",
                    "--db_password",
                    "odoo",
                    "--db_user",
                    "odoo",
                    "--database",
                    "odoo19-main-104",
                    "--limit-time-real",
                    "6000",
                    "--limit-time-cpu",
                    "6000",
                    "--limit-time-worker-cron",
                    "0",
                    "--addons-path",
                    "${config:odoo.addons}",
                    "--update",
                    "${input:moduleList}",
                    "--dev",
                    "all"
                ]
            },
            {
                "name": "Odoo Test",
                "type": "debugpy",
                "request": "launch",
                "program": "${config:odoo.bin}",
                "console": "integratedTerminal",
                "justMyCode": true,
                "args": [
                    "--db_host",
                    "localhost",
                    "--db_password",
                    "odoo",
                    "--db_user",
                    "odoo",
                    "--database",
                    "odooiottest${input:databaseName}",
                    "--addons-path",
                    "${config:odoo.addons}",
                    "--init",
                    "${input:moduleList}",
                    "--test-tag",
                    "${input:testTag}",
                    "--stop-after-init"
                ]
            }
        ]
    },
    "settings": {
        "odoo.bin": "${workspaceFolder}/odoo/odoo/odoo-bin",
        "odoo.addons": "${workspaceFolder}/odoo/odoo/addons,${workspaceFolder}/odoonix/ocaoa,${workspaceFolder}/odoo/design-themes,${workspaceFolder}/oca/fleet,${workspaceFolder}/oca/queue,${workspaceFolder}/oca/reporting-engine,${workspaceFolder}/oca/openupgrade,${workspaceFolder}/oca/server-ux,${workspaceFolder}/oca/account-invoicing,${workspaceFolder}/oca/account-invoice-reporting,${workspaceFolder}/oca/account-reconcile,${workspaceFolder}/oca/account-financial-reporting,${workspaceFolder}/oca/account-financial-tools,${workspaceFolder}/oca/bank-statement-import,${workspaceFolder}/oca/credit-control,${workspaceFolder}/oca/brand,${workspaceFolder}/oca/purchase-workflow,${workspaceFolder}/oca/pos,${workspaceFolder}/oca/web,${workspaceFolder}/oca/website,${workspaceFolder}/oca/hr,${workspaceFolder}/oca/project,${workspaceFolder}/oca/sale-workflow,${workspaceFolder}/oca/server-auth,${workspaceFolder}/oca/server-tools,${workspaceFolder}/oca/server-brand,${workspaceFolder}/oca/product-attribute,${workspaceFolder}/oca/partner-contact,${workspaceFolder}/oca/knowledge,${workspaceFolder}/oca/crm,${workspaceFolder}/odoonix/acm,${workspaceFolder}/odoonix/auxico,${workspaceFolder}/odoonix/brand,${workspaceFolder}/odoonix/connector,${workspaceFolder}/odoonix/crm,${workspaceFolder}/odoonix/gstone,${workspaceFolder}/odoonix/hr,${workspaceFolder}/odoonix/marine,${workspaceFolder}/odoonix/pos,${workspaceFolder}/odoonix/product,${workspaceFolder}/odoonix/sale,${workspaceFolder}/odoonix/sms,${workspaceFolder}/odoonix/social",
        "git.ignoreLimitWarning": true,
        "editor.defaultFormatter": "ms-python.autopep8",
        "editor.wordWrap": "on",
        "editor.wordWrapColumn": 88,
        "editor.rulers": [
            88,
            90
        ],
        "search.exclude": {
            "**/__pycache__/**": true,
            "**/.venv/**": true,
            "**/.tmp/**": true,
            "**/moonsunsoft/**": true
        },
        "files.exclude": {
            "**/__pycache__/**": true
        },
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.languageServer": "Pylance",
        "python.analysis.autoImportCompletions": true,
        "python.analysis.supportAllPythonDocuments": true,
        "python.analysis.enableSyncServer": true,
        "python.terminal.activateEnvInCurrentTerminal": true,
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
            "--tb=short",
            "-v"
        ],
        "python.testing.unittestEnabled": false
    },
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Otoolbox: Update All Git Repositories",
                "command": "otoolbox",
                "type": "shell",
                "args": [
                    "run",
                    "update",
                    "--tags",
                    "git"
                ],
                "problemMatcher": [],
                "presentation": {
                    "reveal": "always"
                },
                "group": "build",
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            {
                "label": "Otoolbox: Add repository",
                "command": "otoolbox",
                "type": "shell",
                "args": [
                    "repo",
                    "add",
                    "${input:repositoryUrlAdd}"
                ],
                "problemMatcher": [],
                "presentation": {
                    "reveal": "always"
                },
                "group": "build",
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            {
                "label": "Otoolbox: Remove repository",
                "command": "otoolbox",
                "type": "shell",
                "args": [
                    "repo",
                    "remove",
                    "${input:repositoryUrlAdd}"
                ],
                "problemMatcher": [],
                "presentation": {
                    "reveal": "always"
                },
                "group": "build",
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            {
                "label": "Otoolbox: Create Addon",
                "command": "${command:python.interpreterPath}",
                "type": "shell",
                "args": [
                    "${workspaceFolder}/odoo/odoo/odoo-bin",
                    "scaffold",
                    "${input:repositoryUrlAdd}"
                ],
                "problemMatcher": [],
                "presentation": {
                    "reveal": "always"
                },
                "group": "build",
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            },
            {
                "label": "Otoolbox: Update VS Code Workspace",
                "command": "otoolbox",
                "type": "shell",
                "args": [
                    "run",
                    "init",
                    "--tags",
                    "odoo-dev.code-workspace"
                ],
                "problemMatcher": [],
                "presentation": {
                    "reveal": "always"
                },
                "group": "build",
                "options": {
                    "cwd": "${workspaceFolder}"
                }
            }
        ],
        "inputs": [
            {
                "id": "repositoryUrlAdd",
                "type": "promptString",
                "description": "Enter the repository URL to add/remove to the workspace"
            }
        ]
    },
    "extensions": {
        "recommendations": [
            "odoo.odoo",
            "github.copilot",
            "github.copilot-chat",
            "ms-python.autopep8",
            "ms-python.python",
            "ms-python.debugpy",
            "ms-python.vscode-python-envs",
            "ms-azuretools.vscode-docker",
            "ms-azuretools.vscode-containers",
            "mechatroner.rainbow-csv",
            "rioj7.command-variable"
        ]
    }
}
