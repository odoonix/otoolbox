{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tests: run all",
      "type": "shell",
      "command": "source ./.venv/bin/activate && python -m pytest tests/",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
