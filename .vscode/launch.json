{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "odooProjectPath",
            "type": "promptString",
            "description": "Enter the Odoo project path",
            "default": "/path/to/odoo"
        },
        {
            "id": "otoolboxCliArgs",
            "type": "pickString",
            "description": "Select command-line arguments",
            "options": [
                "run update --help",
                "run init --tags copilot",
                "ubuntu init",
                "run update --tags odools.toml",
                "run update --tags README.rst",
                "repo list",
                "repo sync-shielded",
                "run verify --tags git",
                "run update --tags odoo-dev.code-workspace"
            ],
            "default": "run update --help"
        }
    ],
    "configurations": [
        {
            "name": "Run otoolbox (select args)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.vscode/otoolbox_debug_runner.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "args": [
                "${input:otoolboxCliArgs}"
            ],
            "cwd": "${input:odooProjectPath}",
            "justMyCode": false
        }
    ]
}