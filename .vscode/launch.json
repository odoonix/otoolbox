{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "odooProjectPath",
            "type": "promptString",
            "description": "Enter the Odoo project path",
            "default": "/path/to/odoo"
        },
        {
            "id": "otoolboxCliArgs",
            "type": "pickString",
            "description": "Select command-line arguments",
            "options": [
                "run --help",
                "run init --help",
                "run init",
                "run init --tags copilot",
                "run update --help",
                "run update",
                "run update --tags odools.toml",
                "run update --tags README.rst",
                "run update --tags documentation",
                "run update --tags ubuntu",
                "run update --tags unitest",
                "run update --tags requirements.txt",
                "run update --tags odoo-dev.code-workspace",
                "run verify --help",
                "run verify --tags git",
                "run verify --tags odoo-dev.code-workspace",
                "repo --help",
                "repo sync-shielded",
                "run init --tags 'odoonix/connector'",
                "repo add 'odoonix/social'",
                "repo add 'odoonix/product'",
                "repo add 'odoo/design-themes'",
                "repo list --help",
                "repo list --no-odoo-addon-folder",
                "repo list --odoo-addon-folder --format=list",
                "repo list",
                "repo list --format=table",
                "repo list --format=list",
            ],
            "default": "run update --help"
        }
    ],
    "configurations": [
        {
            "name": "Run otoolbox (select args)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.vscode/otoolbox_debug_runner.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "args": [
                "${input:otoolboxCliArgs}"
            ],
            "cwd": "${input:odooProjectPath}",
            "justMyCode": false
        }
    ]
}
