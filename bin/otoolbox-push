set -e

function resolve_script_path() {
    local source="${BASH_SOURCE[0]}"
    while [[ -L "$source" ]]; do
        local dir
        dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
        source="$(readlink "$source")"
        [[ $source != /* ]] && source="$dir/$source"
    done
    echo "$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
}

SCRIPT_PATH=$(resolve_script_path)
source "$SCRIPT_PATH/otoolbox-common"

VERBOSE=false
DEBUG=false
NO_PULL=false

function show_help() {
    cat << EOF
Usage: $(basename "$0") [OPTIONS]

Pull and push latest changes for public organization repositories.

OPTIONS:
  --help, -h      Show this help message and exit
  --verbose       Enable verbose output
  --debug         Enable debug mode
    --no-pull       Skip git pull and only push changes

EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            show_help
            exit 0
            ;;
        --verbose)
            export VERBOSE=true
            shift
            ;;
        --debug)
            export VERBOSE=true
            export DEBUG=true
            shift
            ;;
        --no-pull)
            NO_PULL=true
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            show_help >&2
            exit 2
            ;;
    esac
done

_ot_init

if [[ -z "$PUBLIC_ORGANIZATION" ]]; then
    _ot_log_error "PUBLIC_ORGANIZATION is not set."
    exit 1
fi

for dir in "$WORKSPACE_ROOT/$PUBLIC_ORGANIZATION"/*/; do
    if [[ -d "$dir" ]]; then
        project="$(basename "$dir")"
        _ot_log_info "Processing project: $project"
        cd "$WORKSPACE_ROOT/$PUBLIC_ORGANIZATION/$project"
        if [[ "$NO_PULL" != "true" ]]; then
            git pull >> "$LOG_FILE" 2>&1
        else
            _ot_log_info "Skipping pull for $project (--no-pull enabled)."
        fi
        git push >> "$LOG_FILE" 2>&1
    fi
done
